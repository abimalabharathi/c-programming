#python function for merge two dictionaries
def merge_dictionaries(dict1,dict2):
   merged_dict = {**dict1, **dict2}
   return merged_dict
#main
dictionary1 = {'a': 1,'b' : 2}
dictionary2 = {'b' :3,'c' : 4}
#call the function and print
combined_result = merge_dictionaries(dictionary1,dictionary2)
print("Combined Dictionary:", combined_result)
